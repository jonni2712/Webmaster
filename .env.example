# ============================================
# WEBMASTER MONITOR - ENVIRONMENT VARIABLES
# ============================================
# Copia questo file come .env.local per sviluppo locale
# Carica queste variabili su Vercel per produzione

# ============================================
# SUPABASE
# ============================================
# URL del progetto Supabase (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Chiave pubblica anonima (Settings > API > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# Chiave service role - SEGRETA! (Settings > API > service_role secret)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxx

# ============================================
# NEXTAUTH.JS
# ============================================
# URL base dell'applicazione
# Sviluppo: http://localhost:3000
# Produzione: https://tuo-dominio.vercel.app
NEXTAUTH_URL=https://tuo-dominio.vercel.app

# Chiave segreta per cifrare i token JWT (minimo 32 caratteri)
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET=genera-una-chiave-segreta-di-almeno-32-caratteri

# ============================================
# OAUTH PROVIDERS (opzionale)
# ============================================
# GitHub OAuth (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# EMAIL (Resend)
# ============================================
# API Key da https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Indirizzo mittente (deve essere verificato su Resend)
EMAIL_FROM=Webmaster Monitor <noreply@tuodominio.com>

# ============================================
# CRON JOBS
# ============================================
# Chiave segreta per autenticare le chiamate cron
# Genera con: openssl rand -base64 32
CRON_SECRET=genera-una-chiave-segreta-per-cron

# ============================================
# APIS ESTERNE
# ============================================
# Google PageSpeed Insights API (per Core Web Vitals)
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# ============================================
# SICUREZZA
# ============================================
# Chiave per cifrare API keys nel database (32 bytes hex)
# Genera con: openssl rand -hex 32
ENCRYPTION_KEY=

# ============================================
# OPZIONALE - CANALI NOTIFICA
# ============================================
# Slack Webhook URL
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Telegram Bot Token
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Discord Webhook URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxx/xxx
